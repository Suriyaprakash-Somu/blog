{
  "name": "server",
  "version": "1.0.0",
  "description": "Blog Manager API Server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "lint": "biome lint src drizzle.config.ts verify-db.ts --only=suspicious/noExplicitAny --diagnostic-level=error --skip-parse-errors",
    "check:links": "node ../scripts/check-md-links.mjs",
    "check:security": "tsx src/scripts/check-route-security.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "npx tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "npx tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "npx tsx node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "npx tsx node_modules/drizzle-kit/bin.cjs studio",
    "db:reset": "tsx src/scripts/db-reset.ts",
    "db:reset+migrate": "npm run db:reset && npm run db:migrate",
    "db:seed:landing": "tsx --env-file=.env src/scripts/seed-landing.ts",
    "db:seed:prompts": "tsx --env-file=.env src/scripts/seed-prompts.ts",
    "uploads:cleanup": "tsx src/scripts/uploads-cleanup.ts"
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/request-context": "^6.2.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bcryptjs": "^3.0.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "fastify": "^5.7.4",
    "fastify-type-provider-zod": "^6.1.0",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.2.5",
    "pg": "^8.17.2",
    "prom-client": "^15.1.3",
    "rss-parser": "^3.13.0",
    "uuidv7": "^1.1.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@esbuild-kit/esm-loader": "file:vendor/esbuild-kit-esm-loader"
  }
}
