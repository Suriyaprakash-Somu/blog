# Environment (DEV ONLY)
#
# This file is for local development.
# For production: set strong secrets, enable TLS at the edge, and review cookie/security settings.

NODE_ENV=development
PORT=3020
REQUEST_TIMEOUT_MS=30000
CONNECTION_TIMEOUT_MS=10000
KEEP_ALIVE_TIMEOUT_MS=60000
REQUEST_BODY_MAX_BYTES=1048576
COOKIE_SECRET=local-dev-cookie-secret-change-me
JWT_SECRET=local-dev-jwt-secret-change-me
SESSION_TOKEN_PEPPER=local-dev-session-pepper-change-me
SESSION_TTL_DAYS=7
PLATFORM_JWT_TTL_DAYS=1
BCRYPT_ROUNDS=12
COOKIE_SAME_SITE=lax
CSRF_COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=x-csrf-token

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=blog
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=0
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_MAX_USES=0

# CORS
# Comma-separated list. Use your deployed web origin(s) in production.
ALLOWED_ORIGINS=http://localhost:3015,http://127.0.0.1:3015

# File Uploads
UPLOAD_MAX_BYTES=5242880
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,application/pdf,text/plain,text/csv

# Optional malware scanning (ClamAV)
# Set UPLOAD_SCAN_MODE=clamav and ensure the command exists on the server.
# If UPLOAD_SCAN_FAIL_CLOSED=true, uploads are rejected when scanning errors.
UPLOAD_SCAN_MODE=none
UPLOAD_SCAN_COMMAND=clamscan
UPLOAD_SCAN_TIMEOUT_MS=120000
UPLOAD_SCAN_FAIL_CLOSED=false

# Optional orphan cleanup job (single-server friendly)
UPLOAD_ORPHAN_CLEANUP_ENABLED=false
UPLOAD_ORPHAN_CLEANUP_INTERVAL_MINUTES=15
UPLOAD_ORPHAN_CLEANUP_BATCH_SIZE=200

# Metrics
# tenant: requires tenant auth (default)
# none: unauthenticated scrape
# token: requires token header
METRICS_AUTH_MODE=tenant
# METRICS_TOKEN=change-me
